<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteRule ^api/utilsapi/?(.*)$ hostinger-utilsapi/index.php?path=$1 [QSA,L]
RewriteRule ^api/?(.*)$ hostinger-api/index.php?path=$1 [QSA,L]
RewriteRule ^utilsapi/?(.*)$ hostinger-utilsapi/index.php?path=$1 [QSA,L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
</IfModule>
