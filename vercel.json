{
  "version": 2,
  "functions": {
    "api/[...path].js": {
      "maxDuration": 30
    },
    "api/utilsapi/[...path].js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/utilsapi/:path*", "destination": "/api/utilsapi/:path*" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/:path((?!api/)(?!utilsapi/).*)", "destination": "/index.html" }
  ]
}
